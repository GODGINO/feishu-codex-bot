# 飞书应用凭据（必填，在飞书开放平台创建应用获取）
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# Claude Code
# CLAUDE_PATH — Claude CLI 路径，默认自动检测 (which claude)
# CLAUDE_PATH=/usr/local/bin/claude
CLAUDE_MODEL=sonnet
# SESSIONS_DIR — 会话数据目录，默认为项目下的 sessions/
# SESSIONS_DIR=./sessions

# 并发控制
MAX_CONCURRENT=3
MAX_QUEUE_PER_SESSION=5
PROCESS_TIMEOUT=120000

# 日志
LOG_LEVEL=info

# 管理后台
ADMIN_PORT=3333

# 可选：Bot 人设
SYSTEM_PROMPT=你是一个有用的AI助手，通过飞书与用户交流。请简洁地回复。

# ─── Sigma Claude Switcher（自动切换 Claude Max 账号） ─────────────────────
# 安装：bash sigma-switcher/daemon/install.sh
# 启用：bot.sh 会自动拉起（前提：安装 + 下方 SWITCHER_* 填完）。
# 不想用：保持下面字段为空即可，switcher 启动时会 fail-fast 退出，不影响 bot。

# 账号列表（JSON 数组）— 每个是 Claude Max 账号，按顺序轮换 A→B→A
# 注意：外层用单引号包裹，否则 `source .env` 会把 JSON 里的双引号吃掉
# SWITCHER_ACCOUNTS='[{"email":"a@company.com","label":"Max-A"},{"email":"b@company.com","label":"Max-B"}]'

# 接收 Claude magic-link 邮件的统一邮箱（所有账号的邮件都要能到这里，用 +alias 或转发）
# SWITCHER_IMAP_HOST=imap.feishu.cn
# SWITCHER_IMAP_PORT=993
# SWITCHER_IMAP_USER=your-aggregator@example.com
# SWITCHER_IMAP_PASSWORD=<APP_PASSWORD>  # 飞书邮箱专用密码，不是主密码

# 非敏感的默认值（可选，默认已合理）
# SWITCHER_THRESHOLD=90               # 用量百分比阈值，任一 limit 达到就切
# SWITCHER_CHECK_INTERVAL=120         # 主循环周期（秒），默认 2 分钟
# SWITCHER_COOLDOWN_HOURS=5           # 5h session 打满后的冷却（对应 Claude rate-limit 滚动窗口）
# SWITCHER_WEEKLY_COOLDOWN_HOURS=168  # 周用量 fallback 冷却（默认 168h=7d，但通常从页面 "Resets X" 文本解析到精确时间）
# SWITCHER_HTTP_PORT=17222

# IMAP 兜底超时（秒）—— 默认 120，是 fetch_magic_link 直接调用的上限。
# 真正生效的是下面 magic-link 重试逻辑的 per-attempt timeout（默认 60s × 5 次）。
# SWITCHER_IMAP_POLL_TIMEOUT=120
# SWITCHER_MAGIC_LINK_ATTEMPT_TIMEOUT=60   # 每次 magic-link 等待超时（秒），默认 60
# SWITCHER_MAGIC_LINK_MAX_ATTEMPTS=5       # 重发最多次数，超过则切到下一个账号
# SWITCHER_IMAP_POLL_INTERVAL=5     # 每 N 秒扫一次 IMAP（默认 5）
# SWITCHER_IMAP_SCAN_RECENT=30      # 每次扫最近 N 封邮件（默认 30）

# 切换通知（飞书 webhook URL，含 secret token）
# SWITCHER_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
